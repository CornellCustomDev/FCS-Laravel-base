{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "cornell-custom-dev/fcs-laravel-base",
    "type": "project",
    "description": "Cornell Custom Dev Laravel starter kit for FCS.",
    "license": "MIT",
    "repositories": {
        "cds": {
            "type": "vcs",
            "url": "https://github.com/CornellCustomDev/cds"
        },
        "flux-pro": {
            "type": "composer",
            "url": "https://composer.fluxui.dev"
        }
    },
    "require": {
        "php": "^8.2",
        "cornell-custom-dev/cds": "^1.4.1@beta",
        "laravel/framework": "^12.54",
        "laravel/tinker": "^2.11",
        "livewire/flux": "^2.13",
        "livewire/flux-pro": "^2.13",
        "livewire/livewire": "^4.2",
        "livewire/volt": "^1.10"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24",
        "laravel/pail": "^1.2",
        "laravel/pint": "^1.28",
        "laravel/sail": "^1.53",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.9",
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php scripts/init-project.php"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
